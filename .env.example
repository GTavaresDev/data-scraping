# Porta usada no ambiente local.
# Se voce alterar este valor, o servidor local passara a escutar em outra porta.
PORT=3000

# Ajuda a diferenciar comportamentos de desenvolvimento e producao.
# Se removido, o projeto assume "development" como padrao.
NODE_ENV=development

# Endereco alvo do scraping de quotes.
# SCRAPING_BASE_URL segue como fallback para compatibilidade com versoes anteriores.
SCRAPING_QUOTES_BASE_URL=https://quotes.toscrape.com/

# Endereco alvo do scraping da pagina institucional da VisiOne.
SCRAPING_VISIONE_BASE_URL=https://www.visione-web.com/
