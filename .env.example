# Porta usada no ambiente local.
# Se voce alterar este valor, o servidor local passara a escutar em outra porta.
PORT=3000

# Ajuda a diferenciar comportamentos de desenvolvimento e producao.
# Se removido, o projeto assume "development" como padrao.
NODE_ENV=development

# Endereco alvo do scraping.
# Mantemos em variavel de ambiente para mostrar que configuracoes externas
# nao devem ficar "presas" no codigo-fonte quando o projeto cresce.
SCRAPING_BASE_URL=https://quotes.toscrape.com/
